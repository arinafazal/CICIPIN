# Environment variables for Cicipin app

# MongoDB Connection
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
DB_NAME=cicipin

# Flask Secret Key (optional, will use default if not set)
SECRET_KEY=your-secret-key-here

# Upload folder (for Vercel, images won't persist between deployments)
# This is handled automatically in the code
